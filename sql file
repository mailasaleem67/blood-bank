-- expired blood units
SELECT bu.blood_unit_id,
       bg.group_name,
       bu.expiry_date
FROM Blood_Unit bu
JOIN Blood_Group bg ON bu.group_id = bg.group_id
WHERE bu.expiry_date < CURDATE();
-- units expiring soon ( within 7 days)
SELECT bu.blood_unit_id,
       bg.group_name,
       bu.expiry_date
FROM Blood_Unit bu
JOIN Blood_Group bg ON bu.group_id = bg.group_id
WHERE bu.expiry_date BETWEEN CURDATE()
      AND DATE_ADD(CURDATE(), INTERVAL 7 DAY);
-- blood groups with units<5
SELECT bg.group_name,
       SUM(bu.quantity) AS available_units
FROM Blood_Unit bu
JOIN Blood_Group bg ON bu.group_id = bg.group_id
WHERE bu.status = 'Available'
  AND bu.expiry_date >= CURDATE()
GROUP BY bg.group_name
HAVING available_units < 5;
-- approve a blood request
UPDATE Blood_Request
SET status = 'Approved'
WHERE request_id = 1;
-- deduct blood unit quantity after approval
UPDATE Blood_Unit
SET quantity = quantity - 1
WHERE group_id = 3
  AND status = 'Available'
  AND expiry_date >= CURDATE()
LIMIT 1;
-- eligible donor
SELECT donor_id, name
FROM Donor
WHERE last_donation <= DATE_SUB(CURDATE(), INTERVAL 90 DAY);
