-- check availability
SELECT bg.group_name, SUM(bu.quantity) AS total_units
FROM Blood_Unit bu
JOIN Blood_Group bg ON bu.group_id = bg.group_id
WHERE bu.status = 'Available'
GROUP BY bg.group_name;

-- check available common blood groups 
SELECT DISTINCT bg.group_name
FROM Blood_Unit bu
JOIN Blood_Group bg ON bu.group_id = bg.group_id
WHERE bu.status = 'Available'
  AND bu.expiry_date >= CURDATE()
  AND bg.group_name IN ('A+', 'A-', 'O+', 'O-');

