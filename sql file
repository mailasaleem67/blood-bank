-- total approval by blood group 
SELECT bg.group_name,
       SUM(br.quantity) AS total_requested
FROM Blood_Request br
JOIN Blood_Group bg ON br.group_id = bg.group_id
WHERE br.status = 'Approved'
GROUP BY bg.group_name;
-- patient request history 
SELECT p.name,
       br.request_date,
       bg.group_name,
       br.status
FROM Patient p
JOIN Blood_Request br ON p.patient_id = br.patient_id
JOIN Blood_Group bg ON br.group_id = bg.group_id;
-- admin performance  
SELECT a.name,
       COUNT(dr.donation_id) AS donations_handled
FROM Admin a
LEFT JOIN Donation_Record dr ON a.admin_id = dr.admin_id
GROUP BY a.name;
