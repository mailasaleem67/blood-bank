-- auto update stock
DELIMITER $$
CREATE TRIGGER reduce_stock_after_approval
AFTER UPDATE ON Blood_Request
FOR EACH ROW
BEGIN
    IF NEW.status = 'Approved' AND OLD.status <> 'Approved' THEN
        UPDATE Blood_Unit
        SET quantity = quantity - NEW.quantity
        WHERE group_id = NEW.group_id
          AND status = 'Available'
          AND expiry_date >= CURDATE()
        LIMIT 1;
    END IF;
END$$
DELIMITER ;
-- auto mark expired blood
CREATE EVENT expire_blood_event
ON SCHEDULE EVERY 1 DAY
DO
UPDATE Blood_Unit
SET status = 'Expired'
WHERE expiry_date < CURDATE();
-- view availale stock
CREATE VIEW Available_Blood_View AS
SELECT bg.group_name, SUM(bu.quantity) AS total_units
FROM Blood_Unit bu
JOIN Blood_Group bg ON bu.group_id = bg.group_id
WHERE bu.status='Available'
AND bu.expiry_date >= CURDATE()
GROUP BY bg.group_name;

